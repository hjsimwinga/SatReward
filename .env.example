DATABASE_URL="file:./prod.db"
PORT=30001
NODE_ENV=production

# Blink Wallet API — copy values from your Blink dashboard (never commit real keys)
BLINK_API_KEY=
BLINK_BTC_WALLET_ID=
BLINK_USE_STABLESATS=false

# Fixed sats sent as reward
REWARD_SATS=500

# Max rewards each shop can trigger per day
MERCHANT_DAILY_REWARD_LIMIT=5

# Minimum sats spent at a shop to earn a reward
MIN_SPEND_SATS_FOR_REWARD=1000

# Optional
# PAYMENT_POLL_TIMEOUT_SEC=120
